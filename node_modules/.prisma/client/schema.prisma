datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

generator client {
  provider = "prisma-client-js"
}

model Candidate {
  id           String    @id @default(uuid())
  name         String
  email        String    @unique
  phone        String?
  location     String?
  linkedin_url String?
  notes        String?
  created_at   DateTime  @default(now())
  updated_at   DateTime  @updatedAt
  deleted_at   DateTime? // Supports soft deletes (Section 6.3)

  applications Application[]

  @@index([name])
  @@index([email])
}

model Application {
  id                 String   @id @default(uuid())
  candidate_id       String
  job_title          String
  company            String
  status             String // applied, screening, interview, offer, hired, rejected
  applied_at         DateTime
  salary_expectation Int?
  source             String?
  notes              String?
  created_at         DateTime @default(now())
  updated_at         DateTime @updatedAt

  candidate Candidate @relation(fields: [candidate_id], references: [id], onDelete: Cascade)

  @@index([job_title])
  @@index([company])
}
